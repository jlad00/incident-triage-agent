# ── LLM Provider ──────────────────────────────────────────────
# Set to "anthropic" or "ollama"
LLM_PROVIDER=anthropic

# Anthropic — get key at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Ollama — only needed if LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Agent Config ───────────────────────────────────────────────
# Max log lines sent to evidence packet (keep costs down)
MAX_LOG_LINES=200

# Temporal correlation window in minutes
# "Did a deploy happen within N minutes before the incident?"
CORRELATION_WINDOW_MINUTES=30

# Report output directory (relative to project root)
REPORT_OUTPUT_DIR=reports

# ── API ────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO